# === Rust ===
**/target/
**/*.rs.bk
# Nested crate locks (workspace root owns the single Cargo.lock)
crates/**/Cargo.lock
tests/**/Cargo.lock
apps/**/Cargo.lock

# === Node / JS ===
**/node_modules/
**/dist/
**/coverage/
*.local
.npm
.pnpm-store/

# === Tauri / desktop ===
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/WixTools/
apps/desktop/src-tauri/target/

# === Env / secrets / logs ===
.env
.env.*
!.env.example
*.log
logs/

# === Temp DBs / test artifacts ===
*.db
*.db-journal
*.db-wal
*.db-shm
tmp/
temp/
*.tmp
artifacts/tauri-e2e/
artifacts/tauri-e2e-live/
target/live-gui/

# === OS / editors ===
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# NOTE: Do not ignore fixtures, migrations, contracts, reports, or tests.
# Root Cargo.lock and pnpm-lock.yaml are tracked by the workspace owner.

# Integration/local validation outputs (do not commit binaries or run logs)
artifacts/
target/release-rc/


# === Code signing secrets / material (never commit) ===
*.pfx
*.p12
*.pem.key
**/code-sign/
**/signing-secrets/
*.code-sign.json
