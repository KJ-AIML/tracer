{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracer",
  "version": "0.1.0",
  "identifier": "dev.tracer.desktop",
  "mainBinaryName": "tracer-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tracer",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Tracer",
    "category": "DeveloperTool",
    "shortDescription": "Tracer desktop shell for ACP session observability",
    "longDescription": "Tracer is a desktop shell for agent control-plane sessions, presentation, and approvals. Windows RC packaging (W2.3-A) produces an NSIS installer and a portable release binary.",
    "copyright": "Copyright © Tracer contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "useLocalToolsDir": true,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "timestampUrl": null,
      "tsp": false,
      "allowDowngrades": true,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "displayLanguageSelector": false,
        "startMenuFolder": "Tracer"
      }
    }
  },
  "plugins": {}
}
