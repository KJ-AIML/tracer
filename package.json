{
  "name": "tracer",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "test:fake-runtime": "pnpm --filter @tracer/contract-fake-runtime test",
    "test:event-types": "pnpm --filter @tracer/event-types test",
    "test:ui": "pnpm --filter @tracer/ui test",
    "test:desktop": "pnpm --filter @tracer/desktop test",
    "test:tauri-e2e": "node tools/tauri-e2e/run.mjs",
    "test:tauri-e2e:doctor": "node tools/tauri-e2e/doctor.mjs",
    "test:tauri-e2e:l2": "node tools/tauri-e2e/l2-smoke.mjs",
    "test:tauri-e2e:l3i": "node tools/tauri-e2e/l3i-infra.mjs",
    "test:tauri-e2e:gui": "node tools/tauri-e2e/l3j-gui.mjs",
    "test:tauri-e2e:live-gui": "node tools/tauri-e2e/live/lgj.mjs",
    "test:tauri-e2e:live-gui:dry": "node tools/tauri-e2e/live/dry-run.mjs",
    "test:tauri-e2e:live-gui:unit": "node tools/tauri-e2e/live/unit.mjs",
    "test:tauri-e2e:setup": "node tools/tauri-driver/setup.mjs",
    "test:tauri-e2e:reliability": "node tools/tauri-e2e/reliability-selftest.mjs",
    "test:tauri-e2e:inject-fail": "node tools/tauri-e2e/inject-fail.mjs",
    "test:tauri-e2e:repeat-gui": "node tools/tauri-e2e/repeat-gui.mjs",
    "release:windows": "node tools/release/windows-rc.mjs",
    "test:release:windows": "node tools/release/validate-windows.mjs",
    "test:release:upgrade": "node tools/release/upgrade-fixture.mjs",
    "release:provenance": "node tools/release/generate-provenance.mjs",
    "release:provenance:verify": "node tools/release/verify-provenance.mjs",
    "validate:js": "pnpm -r run build && pnpm -r run test",
    "release:sign:doctor": "node tools/release/sign-doctor.mjs",
    "release:sign:test": "node tools/release/sign-test.mjs",
    "release:sign": "node tools/release/sign.mjs",
    "release:verify-signature": "node tools/release/verify-signature.mjs",
    "test:release:signing": "node --test tests/release/windows/signing/*.test.mjs"
  }
}
