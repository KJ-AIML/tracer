{
  "name": "@tracer/release",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows release packaging, provenance, and Authenticode signing readiness (W2.3-A / W2.4.2-A)",
  "scripts": {
    "release:windows": "node ./windows-rc.mjs",
    "validate:windows": "node ./validate-windows.mjs",
    "upgrade:fixture": "node ./upgrade-fixture.mjs",
    "provenance:generate": "node ./generate-provenance.mjs",
    "provenance:verify": "node ./verify-provenance.mjs",
    "identity": "node ./identity-check.mjs",
    "classify-signing": "node ./classify-signing.mjs",
    "release:sign:doctor": "node ./sign-doctor.mjs",
    "release:sign:test": "node ./sign-test.mjs",
    "release:sign": "node ./sign.mjs",
    "release:verify-signature": "node ./verify-signature.mjs",
    "test": "node --test ../../tests/release/windows/signing/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
