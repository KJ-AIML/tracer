{
  "name": "@tracer/tauri-e2e",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "W2.2-A Tauri E2E infrastructure: doctor, L0-L1 boundary, L2 smoke, L3-I driver infra (not L3-J product journey)",
  "scripts": {
    "test": "node ./run.mjs",
    "test:policy": "node ./run.mjs --policy-only",
    "test:boundary": "node ./run.mjs --boundary-only",
    "test:gui-probe": "node ./run.mjs --gui-probe",
